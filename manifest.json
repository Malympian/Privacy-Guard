{
  "manifest_version": 3,
  "name": "Privacy Guard",
  "version": "1.6.0",
  "description": "Blocks common tracking beacons and spoofs behavioral event signals on allowed sites only.",
  "permissions": ["storage", "tabs", "scripting", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Privacy Guard — pin this icon to see the status dot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gate.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["guard.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN",
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["guard.js", "observe.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
